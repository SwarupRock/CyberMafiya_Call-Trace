<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_screen_bg"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="24dp"
        android:paddingEnd="18dp"
        android:paddingBottom="34dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/login_panel_bg"
            android:elevation="10dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="18dp"
                android:background="@drawable/login_shield_halo"
                android:padding="18dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Call Trace logo"
                    android:src="@drawable/ic_shield" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans"
                android:gravity="center"
                android:text="Welcome Back"
                android:textColor="@color/text_primary"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_auth_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans"
                android:gravity="center"
                android:text="Login to continue to your account"
                android:textColor="@color/text_dim"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/layout_email_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/login_input_bg"
                    android:drawableStart="@drawable/ic_mail"
                    android:drawablePadding="12dp"
                    android:fontFamily="sans"
                    android:hint="Email Address"
                    android:inputType="textEmailAddress"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/login_input_bg"
                    android:drawableStart="@drawable/ic_lock"
                    android:drawableEnd="@drawable/ic_eye"
                    android:drawablePadding="12dp"
                    android:fontFamily="sans"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cb_remember_me"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:buttonTint="@color/cyber_cyan"
                        android:checked="true"
                        android:fontFamily="sans"
                        android:text="Remember me"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_forgot_password"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:fontFamily="sans"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="2dp"
                        android:text="Forgot Password?"
                        android:textColor="@color/cyber_cyan"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_email_signin"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/login_primary_button"
                    android:drawableEnd="@drawable/ic_arrow_right"
                    android:backgroundTint="@null"
                    android:elevation="8dp"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:paddingStart="26dp"
                    android:paddingEnd="18dp"
                    android:text="Sign In"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_phone_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/login_input_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinner_country_code"
                        android:layout_width="92dp"
                        android:layout_height="match_parent"
                        android:backgroundTint="@color/cyber_cyan"
                        android:popupBackground="@color/obsidian_800"
                        android:spinnerMode="dropdown"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:background="#334B6382" />

                    <EditText
                        android:id="@+id/et_phone"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:drawableStart="@drawable/ic_phone"
                        android:drawablePadding="10dp"
                        android:fontFamily="sans"
                        android:hint="Phone Number"
                        android:inputType="phone"
                        android:paddingStart="12dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="15sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_send_otp"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/login_primary_button"
                    android:backgroundTint="@null"
                    android:elevation="8dp"
                    android:fontFamily="sans"
                    android:text="Send OTP"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_email_mode"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:text="Use email login instead"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_phone_recovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:text="Forgot phone access? Use email reset or Google sign-in."
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_otp_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_otp_sent_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans"
                    android:text="OTP sent to phone"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_otp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/login_input_bg"
                    android:fontFamily="sans"
                    android:hint="Enter 6-digit OTP"
                    android:inputType="number"
                    android:letterSpacing="0.22"
                    android:maxLength="6"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textAlignment="center"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/btn_verify_otp"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/login_primary_button"
                    android:backgroundTint="@null"
                    android:elevation="8dp"
                    android:fontFamily="sans"
                    android:text="Verify OTP"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_resend_otp"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:text="Forgot code? Resend OTP"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_otp_email_mode"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:text="Use email login instead"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_provider_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:text="OR CONTINUE WITH"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/btn_google_signin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/login_social_button"
                    android:backgroundTint="@null"
                    android:drawableStart="@drawable/ic_google"
                    android:drawablePadding="10dp"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="Google"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_phone_mode"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/login_social_button"
                    android:backgroundTint="@null"
                    android:drawableStart="@drawable/ic_phone"
                    android:drawablePadding="12dp"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="Continue with Phone Number"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_email_signup"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="14dp"
                android:background="@android:color/transparent"
                android:backgroundTint="@null"
                android:fontFamily="sans"
                android:text="Don't have an account?  Sign Up"
                android:textAllCaps="false"
                android:textColor="@color/cyber_cyan"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans"
            android:gravity="center"
            android:textColor="@color/neon_crimson"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
