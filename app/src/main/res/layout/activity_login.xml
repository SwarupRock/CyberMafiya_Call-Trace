<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_black"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="26dp"
        android:paddingEnd="22dp"
        android:paddingBottom="34dp">

        <FrameLayout
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:background="@drawable/login_shield_halo"
            android:padding="18dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Scam Shield Logo"
                android:src="@drawable/ic_shield"
                android:tint="@color/cyber_cyan" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.16"
            android:text="SCAM SHIELD AI"
            android:textColor="@android:color/white"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.06"
            android:text="Cyber defense for calls and messages"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/login_panel_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="ACCOUNT ACCESS"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_auth_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="Login first with email. New here? Create an account below."
                android:textColor="@color/text_dim"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/layout_provider_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_google_signin"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_google_bg"
                    android:drawableStart="@drawable/ic_google"
                    android:drawablePadding="8dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="GOOGLE"
                    android:textColor="@color/obsidian_black"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_phone_mode"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/login_demo_button"
                    android:drawableStart="@drawable/ic_phone"
                    android:drawablePadding="8dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="PHONE"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_email_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:text="EMAIL"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/login_input_bg"
                    android:fontFamily="monospace"
                    android:hint="you@example.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#5F6970"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:text="PASSWORD"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/login_input_bg"
                    android:fontFamily="monospace"
                    android:hint="Minimum 6 characters"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#5F6970"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btn_email_signin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/login_success_button"
                    android:fontFamily="monospace"
                    android:text="LOGIN"
                    android:textColor="@color/obsidian_black"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_email_signup"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/login_demo_button"
                    android:fontFamily="monospace"
                    android:text="CREATE ACCOUNT"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_forgot_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Forgot password?"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_phone_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:text="PHONE NUMBER"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/login_input_bg"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinner_country_code"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:backgroundTint="@color/text_dim"
                        android:paddingStart="4dp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="#333333" />

                    <EditText
                        android:id="@+id/et_phone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:fontFamily="monospace"
                        android:hint="234 567 8900"
                        android:inputType="phone"
                        android:paddingStart="12dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="#5F6970"
                        android:textSize="15sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_send_otp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/login_primary_button"
                    android:fontFamily="monospace"
                    android:text="SEND OTP"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_email_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Use email login instead"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_phone_recovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="6dp"
                    android:text="Forgot phone access? Use email reset or Google sign-in."
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_otp_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:text="VERIFICATION CODE"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_otp_sent_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="OTP sent to phone"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/et_otp"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/login_input_bg"
                    android:fontFamily="monospace"
                    android:hint="Enter 6-digit OTP"
                    android:inputType="number"
                    android:letterSpacing="0.3"
                    android:maxLength="6"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textAlignment="center"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#5F6970"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/btn_verify_otp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/login_success_button"
                    android:fontFamily="monospace"
                    android:text="VERIFY OTP"
                    android:textColor="@color/obsidian_black"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_resend_otp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Forgot code? Resend OTP"
                    android:textColor="@color/cyber_cyan"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_otp_email_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Use email login instead"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:textColor="@color/neon_crimson"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="monospace"
            android:text="On-device monitoring. User-controlled AI key."
            android:textColor="#596367"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
