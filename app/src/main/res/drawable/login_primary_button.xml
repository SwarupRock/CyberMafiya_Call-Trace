<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#552B95FF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:centerColor="#1EBEFF"
                android:endColor="#236BFF"
                android:startColor="#28D7FF" />
            <corners android:radius="26dp" />
        </shape>
    </item>
</layer-list>
